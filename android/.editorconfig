root = true

[*.{kt,kts}]
# The codebase follows Android Studio Kotlin style. ktlint defaults to the
# stricter "ktlint_official" style, which this code does not target — align them.
ktlint_code_style = android_studio

# On top of the style alignment, disable a few opinionated, largely
# non-auto-correctable rules whose cost (CI round-trips, hand-edits) outweighs
# their benefit — especially for machine-written code. Harmless if the style
# above already relaxes them.
ktlint_standard_value-argument-comment = disabled
ktlint_standard_comment-wrapping = disabled
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_no-empty-first-line-in-class-body = disabled
