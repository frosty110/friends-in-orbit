<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Orbit" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/charcoal</item>
        <item name="android:statusBarColor">@color/charcoal</item>
        <item name="android:navigationBarColor">@color/charcoal</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    <style name="Theme.Orbit.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/charcoal</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Orbit</item>
    </style>
</resources>
